# Telegram
# Bot token from @BotFather
TELEGRAM_BOT_TOKEN=your_bot_token_here
# Channel username or numeric ID where posts will be published
TELEGRAM_CHANNEL_ID=@YourChannelUsername
# Numeric Telegram user ID of the admin who reviews/approves posts.
# Get yours from @userinfobot. Required when REQUIRE_ADMIN_APPROVAL=true.
TELEGRAM_ADMIN_USER_ID=0
# When true, every generated post is sent to the admin DM with
# approve/reject buttons before publishing to the channel.
# Set to false once you trust the bot's output.
REQUIRE_ADMIN_APPROVAL=true
# Optional HTTP proxy for Telegram traffic — needed when the VPS sits in
# a region where the Telegram Bot API is blocked (e.g. RU). Leave blank
# to connect directly. Format:
#   http://user:pass@host:port  or  http://host:port
TELEGRAM_PROXY_URL=
# Optional HTTP proxy for ALL OTHER outbound traffic (Fortnite-API,
# fortnite.com, YouTube RSS, Reddit, nitter, fortnite.gg, Closerouter).
# Same format. Set this when your VPS is in RU / blocked
# region and direct connections to western services fail.
OUTBOUND_PROXY_URL=

# AI provider (Closerouter / OpenAI compatible)
# Keep the real key only in .env or environment variables. Never commit it.
CLOSEROUTER_BASE_URL=https://api.closerouter.dev
CLOSEROUTER_API_KEY=your_closerouter_api_key_here
CLOSEROUTER_TEXT_MODEL=openai/gpt-5.5
CLOSEROUTER_IMAGE_MODEL=openai/gpt-image-2
IMAGE_SIZE=1536x864

# Optional Telegram custom emoji IDs.
# Leave empty to use normal Unicode emoji. If you have custom emoji IDs,
# the bot will render them via <tg-emoji emoji-id="...">.
CUSTOM_EMOJI_NEWS_ID=
CUSTOM_EMOJI_SHOP_ID=
CUSTOM_EMOJI_CHAT_ID=
CUSTOM_EMOJI_ALERT_ID=

# Legacy names are still supported for compatibility:
# LLM_API_URL=https://api.closerouter.dev
# LLM_API_KEY=your_closerouter_api_key_here
# LLM_MODEL=openai/gpt-5.5
# IMAGE_API_URL=https://api.closerouter.dev
# IMAGE_API_KEY=your_closerouter_api_key_here
# IMAGE_MODEL=openai/gpt-image-2

# Database
# Full async PostgreSQL connection string
DATABASE_URL=postgresql+asyncpg://fortnite:password@postgres:5432/fortnite_bot
# PostgreSQL username
POSTGRES_USER=fortnite
# PostgreSQL password
POSTGRES_PASSWORD=password
# PostgreSQL database name
POSTGRES_DB=fortnite_bot

# Redis
# Redis connection URL used for caching and task queuing
REDIS_URL=redis://redis:6379/0

# Shop
# URL of the shop to promote in posts
SHOP_URL=https://bag1-v-bucks.shop/

# Reddit (optional, for r/FortniteLeaks)
# Reddit app client ID (create at https://www.reddit.com/prefs/apps)
REDDIT_CLIENT_ID=your_reddit_client_id
# Reddit app client secret
REDDIT_CLIENT_SECRET=your_reddit_client_secret
# User-agent string for Reddit API requests
REDDIT_USER_AGENT=FortniteNewsBot/1.0

# Publishing limits
# Maximum number of posts to publish per day
MAX_POSTS_PER_DAY=20
# Minimum relevance/quality score (0-100) required to publish a post
MIN_SCORE_TO_PUBLISH=70
